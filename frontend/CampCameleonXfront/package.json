{
  "name": "campcameleonx-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Interface moderne pour CampCameleonX - Dashboard admin et site public",
  "author": "CampCameleonX Team",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "type-check": "vue-tsc --noEmit",
    "clean": "rm -rf dist node_modules/.vite",
    "analyze": "vite build --mode analyze"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@fullcalendar/core": "^6.1.18",
    "@fullcalendar/daygrid": "^6.1.18",
    "@fullcalendar/interaction": "^6.1.18",
    "@fullcalendar/timegrid": "^6.1.18",
    "@fullcalendar/vue3": "^6.1.18",
    "@popperjs/core": "^2.11.8",
    "axios": "^1.9.0",
    "bootstrap": "^5.3.6",
    "chart.js": "^4.4.1",
    "core-js": "^3.36.0",
    "pinia": "^3.0.1",
    "quill": "^1.3.7",
    "vue": "^3.5.13",
    "vue-count-to": "^1.0.13",
    "vue-flatpickr-component": "^11.0.4",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.21.1",
    "prettier": "3.5.3",
    "sass": "^1.71.1",
    "sass-embedded": "^1.89.2",
    "terser": "^5.31.0",
    "typescript": "^5.6.0",
    "vite": "^6.2.4",
    "vite-plugin-vue-devtools": "^7.7.2",
    "vue-tsc": "^2.1.10"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "keywords": [
    "vue3",
    "vite",
    "camping",
    "dashboard",
    "admin",
    "pinia",
    "sass",
    "responsive"
  ]
}
