# ====================================
# APP
# ====================================
APP_NAME=CameleonCore
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Paris
APP_URL=http://localhost:8000
APP_FRONTEND_URL=http://localhost:5173
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR
APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# ====================================
# LOG
# ====================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ====================================
# DATABASE
# ====================================
DB_CONNECTION=pgsql
DB_HOST=myPostgresCore
DB_PORT=5432
DB_DATABASE=cameleoncore
DB_USERNAME=postgres
DB_PASSWORD=secret

# PgAdmin (dev only)
PGADMIN_EMAIL=admin@cameleoncore.local
PGADMIN_PASSWORD=secret

# ====================================
# INSTANCE (CameleonCore)
# ====================================
INSTANCE_NAME="Mon Activité"
INSTANCE_TYPE=hotel
INSTANCE_LOGO=/images/logo.png
INSTANCE_COUNTRY=FR
INSTANCE_EMAIL=contact@example.com
INSTANCE_PHONE=
INSTANCE_ADDRESS=
INSTANCE_SIRET=

# Modules
MODULE_BOOKING=true
MODULE_INVOICING=true
MODULE_CALENDAR=true
MODULE_REVIEWS=false
MODULE_ANALYTICS=false
MODULE_RBAC=false
MODULE_STAFF=false
MODULE_QUOTE=false

# Productables (comma-separated: room,activity,menu,dish,ingredient)
INSTANCE_PRODUCTABLES=menu,dish

# Features
FEATURE_DEPOSIT=true
FEATURE_DEPOSIT_PCT=30
FEATURE_SEASONAL=true
FEATURE_E_INVOICING=false
FEATURE_GUEST_COUNT=true
FEATURE_CHECKIN=false

# ====================================
# STRIPE
# ====================================
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_MODE=deposit

# ====================================
# FACTPULSE (e-invoicing)
# ====================================
FACTPULSE_ENABLED=false
FACTPULSE_API_KEY=
FACTPULSE_SANDBOX=true

# ====================================
# SESSION & CACHE
# ====================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ====================================
# MAIL (dev: MailHog)
# ====================================
MAIL_MAILER=smtp
MAIL_HOST=myMailhogCore
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@cameleoncore.local
MAIL_FROM_NAME="${INSTANCE_NAME}"
CONTACT_EMAIL=contact@cameleoncore.local

# ====================================
# FRONTEND (Vite)
# ====================================
VITE_APP_NAME="${APP_NAME}"
VITE_API_URL=http://localhost:8000/api